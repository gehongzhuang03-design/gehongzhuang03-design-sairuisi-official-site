PORT=3001
CORS_ORIGIN=https://www.example.com

# 后台管理口令。生产环境请务必修改。
ADMIN_TOKEN=srs-admin-2026

# 官网线索接收邮箱。
LEAD_EMAIL_TO=1760772194@qq.com

# QQ 邮箱 SMTP 示例：
# 1. 登录 QQ 邮箱网页版
# 2. 设置 -> 账号 -> POP3/IMAP/SMTP/Exchange/CardDAV/CalDAV 服务
# 3. 开启 SMTP 服务并生成“授权码”
# 4. SMTP_PASS 填授权码，不是 QQ 登录密码
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=1760772194@qq.com
SMTP_PASS=这里填写QQ邮箱SMTP授权码
SMTP_FROM=1760772194@qq.com
